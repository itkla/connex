<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ooo.klae.connex.backend.mappers.NoteMapper">

  <resultMap id="NoteResult" type="Note">
    <id     property="id"        column="id"/>
    <result property="content"   column="content"/>
    <result property="createdAt" column="created_at"/>
    <result property="updatedAt" column="updated_at"/>
    <association property="author" javaType="User">
      <id property="id" column="author_id"/>
    </association>
    <association property="person" javaType="Person">
      <id property="id" column="person_id"/>
    </association>
    <association property="deal" javaType="Deal">
      <id property="id" column="deal_id"/>
    </association>
  </resultMap>

  <sql id="noteColumns">
    id, content, author_id, person_id, deal_id, created_at, updated_at
  </sql>

  <select id="getAllNotes" resultMap="NoteResult">
    SELECT <include refid="noteColumns"/> FROM note ORDER BY created_at DESC
  </select>

  <select id="getNotesByPersonId" resultMap="NoteResult">
    SELECT <include refid="noteColumns"/> FROM note
    WHERE person_id = #{personId} ORDER BY created_at DESC
  </select>

  <select id="getNotesByDealId" resultMap="NoteResult">
    SELECT <include refid="noteColumns"/> FROM note
    WHERE deal_id = #{dealId} ORDER BY created_at DESC
  </select>

  <select id="getNoteById" resultMap="NoteResult">
    SELECT <include refid="noteColumns"/> FROM note WHERE id = #{id}
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO note (content, author_id, person_id, deal_id)
    VALUES (
      #{content}, #{author.id},
      <choose>
        <when test="person != null">#{person.id}</when>
        <otherwise>NULL</otherwise>
      </choose>,
      <choose>
        <when test="deal != null">#{deal.id}</when>
        <otherwise>NULL</otherwise>
      </choose>
    )
  </insert>

  <update id="update">
    UPDATE note
    SET content = #{content},
        author_id = #{author.id},
        person_id =
          <choose>
            <when test="person != null">#{person.id}</when>
            <otherwise>NULL</otherwise>
          </choose>,
        deal_id =
          <choose>
            <when test="deal != null">#{deal.id}</when>
            <otherwise>NULL</otherwise>
          </choose>
    WHERE id = #{id}
  </update>

  <delete id="delete">DELETE FROM note WHERE id = #{id}</delete>
</mapper>
